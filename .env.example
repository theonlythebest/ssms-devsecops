# ---------------------------------------------------------------------------
# Copy to .env and fill with REAL values before `docker compose up`.
# Ansible renders this file automatically on the EC2 from group_vars/all.yml.
# NEVER commit a real .env -- it's in .gitignore.
# ---------------------------------------------------------------------------

# ---- MariaDB ----
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=ssms
MYSQL_USER=ssmsuser
MYSQL_PASSWORD=change-me-strong

# ---- Backend ----
DATABASE_URL=mysql+pymysql://ssmsuser:change-me-strong@mariadb:3306/ssms?charset=utf8mb4
JWT_SECRET=please-generate-32-bytes-of-randomness
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
SEED_ON_STARTUP=true

# ---- Grafana ----
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change-me
